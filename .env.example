# KrishiNyay AI demo configuration

# FastAPI / hosting
PORT=8000
APP_URL=http://localhost:8000

# Public hosted demo mode.
# Use these values for the Hugging Face Spaces demo.
DEMO_PUBLIC=false
CHROMA_PATH=chroma_db
CHROMA_RUNTIME_PATH=
CHUNKS_DIR=data/chunks
LLM_PROVIDER=auto

# Optional hosted LLM providers. Leave empty to use template fallback.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.0-flash-exp:free
ANTHROPIC_API_KEY=

# Optional local LLM path. Start Ollama separately if using it.
OLLAMA_MODEL=llama3.1:8b

# Optional Phase 7 mandi-price API.
# Weather uses Open-Meteo by default and links IMD for official verification.
# Mandi prices use Data.gov.in Agmarknet only when a key is configured.
DATA_GOV_IN_API_KEY=
AGMARKNET_API_KEY=
AGMARKNET_RESOURCE_ID=9ef84268-d588-465a-a308-a864a43d0070

# Optional demo/admin-only live text ingest.
# Keep disabled for public deployments so arbitrary users cannot poison the RAG index.
ENABLE_LIVE_INGEST=false
LIVE_INGEST_TOKEN=
